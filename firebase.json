{
  "hosting": {
    "public": "out",
    "predeploy": [
      "npm run build"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/dashboard",
        "destination": "/dashboard.html"
      },
      {
        "source": "/groups",
        "destination": "/groups.html"
      },
      {
        "source": "/meetings",
        "destination": "/meetings.html"
      },
      {
        "source": "/settings",
        "destination": "/settings.html"
      }
    ]
  }
} 